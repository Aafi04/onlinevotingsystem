    /**
     * Acceptance Criteria 1: Add a test that mocks a `SQLException` to verify that DAO methods handle it gracefully without crashing.
     * Constraint: Zero new external dependencies (no Mockito).
     * Approach: Test `SQLException` propagation by passing an invalid SQL query to an existing Dao method.
     * This verifies `Dao` doesn't crash and correctly throws `SQLException` for invalid database operations.
     */
    @Test
    public void testDaoMethodThrowsSQLExceptionForInvalidQuery() {
        // Using `loginValidation` which takes a raw SQL string to force an `SQLException`
        // by providing syntactically incorrect SQL or referencing a non-existent table.
        String invalidSql = "SELECT * FROM non_existent_table WHERE 1=1";
        assertThrows(SQLException.class, () -> Dao.loginValidation(invalidSql),
                "Dao method should throw SQLException for an invalid query.");
    }

    /**
     * Acceptance Criteria 2: Add a test to ensure that registering a voter with a pre-existing voter card number results in a failure.
     */
    @Test
    public void testRegisterDuplicateVoterIdFails() throws SQLException {
        String voterId = "DUP" + generateUniqueId(); // Unique ID for this test run
        Model voterModel = new Model();
        voterModel.setVoterId(voterId);
        voterModel.setFullName("Duplicate Voter");
        voterModel.setUserName("dup_voter_" + voterId);
        voterModel.setGender("Female");
        voterModel.setDob("1985-05-05");
        voterModel.setEmail("dup_voter@" + voterId + ".com");
        voterModel.setPass("dupPass123");

        // First registration - should succeed
        int firstResult = Dao.register(voterModel);
        assertEquals(1, firstResult, "First registration with unique voter ID should succeed.");

        // Second registration with the same voterId - should fail (return 0 or throw exception)
        // Assuming Dao.register returns 0 for a duplicate entry or other failure, consistent with typical DAO insert operations.
        int secondResult = Dao.register(voterModel);
        assertEquals(0, secondResult, "Second registration with duplicate voter ID should fail.");

        // Cleanup: Delete the registered voter to ensure test isolation
        Dao.deleteVoter(voterId);
    }

