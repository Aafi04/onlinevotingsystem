    /**
     * Acceptance Criteria 5: Add a test to verify that list-retrieval methods (e.g., `getPartyList`) return an empty collection when the database table is empty.
     * Assumption: `Dao.getPartyList()` method exists in `Dao.java` and returns `List<Model>`.
     * Assumption: `Dao.addParty()` and `Dao.deleteParty()` exist for controlled setup and cleanup.
     * To ensure the table is "empty" for this test, we add a temporary party and immediately delete it.
     * This makes the test self-contained regarding its data, but does not guarantee the table is globally empty
     * of data from other sources/tests. A dedicated test database or transaction management would be ideal for full isolation.
     */
    @Test
    public void testGetPartyListReturnsEmptyWhenTableIsEmpty() throws SQLException {
        // Add a temporary party and immediately delete it to ensure cleanup works
        // and to simulate a state where no known parties exist from this test's actions.
        String tempPartyCode = "TMP" + generateUniqueId().substring(0, 5).toUpperCase();
        Model tempParty = new Model();
        tempParty.setPartyCode(tempPartyCode);
        tempParty.setPartyName("Temporary Party");
        tempParty.setPartyLeader("Temp Leader");
        Dao.addParty(tempParty);
        Dao.deleteParty(tempPartyCode);

        // Now, get the list and assert it's empty.
        // This relies on the assumption that no other parties exist in the database from other tests or initial setup.
        List<Model> partyList = Dao.getPartyList();
        assertNotNull(partyList, "getPartyList should return a non-null list.");
        assertTrue(partyList.isEmpty(), "getPartyList should return an empty list when no parties exist (or after cleanup).");
    }
