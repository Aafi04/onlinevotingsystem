<%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %>
<c:set var="isAdminContext" value="true" scope="request"/>
<jsp:include page="header.jsp" />
<c:remove var="isAdminContext" scope="request"/>