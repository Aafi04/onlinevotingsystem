import com.Dao.Dao;
import com.Model.Model;
import org.junit.jupiter.api.*;

import java.sql.ResultSet;
import java.sql.SQLException;
import java.util.List; // Added for getPartyList
import java.util.UUID; // Added for unique IDs

import static org.junit.jupiter.api.Assertions.*;

public class DaoTest {

    // Helper method to generate unique IDs for test data
    private String generateUniqueId() {
        return UUID.randomUUID().toString().substring(0, 8); // Shorten UUID for practicality if DB fields have length limits
    }

    @Test
    public void testLoginValidation() throws SQLException {
        String sql = "SELECT * FROM admin WHERE username='Aafi' AND password='password123'";
        ResultSet rs = Dao.loginValidation(sql);
        assertTrue(rs.next());
    }

    @Test
    public void testAdminValid() throws SQLException {
        Model model = new Model();
        model.setUserName("Aafi");
        model.setPass("password123");
        ResultSet rs = Dao.adminValid(model);
        assertTrue(rs.next());
    }

    @Test
    public void testVoterValid() throws SQLException {
        Model model = new Model();
        model.setVoterId("11111111");
        model.setPass("11111111");
        ResultSet rs = Dao.voterValid(model);
        assertTrue(rs.next());
    }

    @Test
    public void testRegister() throws SQLException {
        Model model = new Model();
        model.setVoterId("987654321");
        model.setFullName("John Doe");
        model.setUserName("johndoe");
        model.setGender("Male");
        model.setDob("1990-01-01");
        model.setEmail("johndoe@example.com");
        model.setPass("password123");
        int result = Dao.register(model);
        assertEquals(1, result);
        // Clean up the voter registered by this test to ensure test isolation
        Dao.deleteVoter("987654321");
    }

    @Test
    public void testContact() throws SQLException {
        Model model = new Model();
        model.setFullName("Jane Doe");
        model.setCompanyName("CompanyX");
        model.setEmail("janedoe@example.com");
        model.setMessage("Hello, this is a test message.");
        int result = Dao.contact(model);
        assertEquals(1, result);
    }

    @Test
    public void testDeleteVoter() throws SQLException {
        // First, register a voter to delete to ensure it exists
        String voterIdToDelete = generateUniqueId();
        Model model = new Model();
        model.setVoterId(voterIdToDelete);
        model.setFullName("Voter To Delete");
        model.setUserName("voter_to_delete_" + voterIdToDelete);
        model.setGender("Other");
        model.setDob("2000-01-01");
        model.setEmail("delete_" + voterIdToDelete + "@example.com");
        model.setPass("deletePass");
        Dao.register(model);

        int result = Dao.deleteVoter(voterIdToDelete);
        assertEquals(1, result, "Delete voter should return 1 for success.");

        // Verify it's actually deleted (e.g., voterValid returns no results)
        Model checkModel = new Model();
        checkModel.setVoterId(voterIdToDelete);
        checkModel.setPass("deletePass"); // Password might be needed for voterValid
        ResultSet rs = Dao.voterValid(checkModel);
        assertFalse(rs.next(), "Voter should not be valid after deletion.");
    }

