    public void testDoPost_SuccessfulRegistration_RedirectsToHomePage() throws ServletException, IOException {
        // Arrange
        mockRegistrationParameters("VOTER456", "John Doe", "johndoe", "Male", "2000-01-01", "john.doe@example.com", "password123");

        // Act
        // Note: Dao.register is a static method. Standard Mockito cannot mock static methods directly.
        // This test assumes Dao.register would return a non-zero value for a successful registration.
        // The test verifies the servlet's redirection logic based on this assumed outcome.
        servlet.doPost(request, response);

        // Assert
        verify(response).sendRedirect("home.jsp?msg=success");
